# MongoDB Atlas Connection URI
# Replace with your own connection string: mongodb+srv://<username>:<password>@cluster.xxxx.mongodb.net/rommo?retryWrites=true&w=majority
MONGODB_URI=mongodb+srv://admin:password@cluster.xxxx.mongodb.net/rommo?retryWrites=true&w=majority

# Port the backend server will run on
PORT=5000

# SMTP Email Settings (Nodemailer)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM="Rommo Workspaces" <your-email@gmail.com>
